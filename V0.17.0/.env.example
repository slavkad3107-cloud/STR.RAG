# ============================================================
#  ПМООС-RAG — ключи API и настройки окружения
#  Скопируйте этот файл в  %USERPROFILE%\.pmoos-rag\.env   (Windows)
#                    или  ~/.pmoos-rag/.env                (Linux/macOS)
#  Можно также задавать ключи прямо в интерфейсе (вкладка настроек слева).
# ============================================================

# --- Ключи провайдеров ИИ (заполните те, что используете) ---
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
MOONSHOT_API_KEY=
MISTRAL_API_KEY=

# --- HuggingFace (необязательно): ускоряет загрузку bge-m3 / reranker,
#     убирает предупреждение про неавторизованные запросы ---
HF_TOKEN=

# --- Каталог данных (RAG-база, модели, .env). По умолчанию ~/.pmoos-rag ---
#     База лежит ОТДЕЛЬНО от приложения, поэтому переустановка не сбрасывает индекс.
# PMOOS_DATA_DIR=D:\pmoos-data

# --- Ollama (локальные модели). По умолчанию http://localhost:11434 ---
# OLLAMA_HOST=http://localhost:11434
